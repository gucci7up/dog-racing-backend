generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CASHIER
  PLAYER
}

enum RaceStatus {
  OPEN
  CLOSED
  RUNNING
  FINISHED
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  username  String   @unique
  email     String   @unique
  password  String
  role      Role     @default(PLAYER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Video {
  id        String   @id @default(uuid()) @db.Uuid
  nombre    String   @unique
  resultado String
  archivo   String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  races Race[]
  queue VideoQueue[]
}

model Race {
  id        String     @id @default(uuid()) @db.Uuid
  numero    Int        @unique
  videoId   String     @db.Uuid
  resultado String
  status    RaceStatus @default(OPEN)
  openAt    DateTime?
  closeAt   DateTime?
  runAt     DateTime?
  finishedAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  video Video @relation(fields: [videoId], references: [id])
}

model VideoQueue {
  id        String   @id @default(uuid()) @db.Uuid
  videoId   String   @db.Uuid
  position  Int
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  video Video @relation(fields: [videoId], references: [id])

  @@index([used, position])
  @@index([videoId])
  @@unique([position])
}
