generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CASHIER
}

enum RaceStatus {
  OPEN
  CLOSED
  RUNNING
  FINISHED
}

enum TicketStatus {
  PENDING
  WON
  LOST
  PAID
  CANCELLED
}

enum BetType {
  WINNER
  EXACTA
  TRIFECTA
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  username  String   @unique
  email     String   @unique
  password  String
  role      Role     @default(CASHIER)
  agencyId  String?  @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agency  Agency? @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  tickets Ticket[]
  cancellationCodes TicketCancellationCode[]

  @@index([agencyId])
}

model Agency {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  code      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
}

model Video {
  id        String   @id @default(uuid()) @db.Uuid
  nombre    String   @unique
  resultado String
  archivo   String
  activo    Boolean  @default(true)
  durationSeconds Int @default(42)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  races Race[]
  queue VideoQueue[]
}

model Race {
  id        String     @id @default(uuid()) @db.Uuid
  numero    Int        @unique
  videoId   String     @db.Uuid
  resultado String
  status    RaceStatus @default(OPEN)
  openAt    DateTime?
  closeAt   DateTime?
  runAt     DateTime?
  finishedAt DateTime?
  saleStartAt DateTime?
  saleEndAt DateTime?
  videoStartedAt DateTime?
  videoFinishedAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  video Video @relation(fields: [videoId], references: [id])

  tickets Ticket[]
  odds    RaceOdds[]
}

model VideoQueue {
  id        String   @id @default(uuid()) @db.Uuid
  videoId   String   @db.Uuid
  position  Int
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  video Video @relation(fields: [videoId], references: [id])

  @@index([used, position])
  @@index([videoId])
  @@unique([position])
}

model QueueState {
  id              String   @id @default(uuid()) @db.Uuid
  currentPosition Int      @default(0)
  cycleNumber     Int      @default(1)
  updatedAt       DateTime @updatedAt
}

model Ticket {
  id           String       @id @default(uuid()) @db.Uuid
  ticketNumber Int          @unique
  raceId       String       @db.Uuid
  userId       String       @db.Uuid
  publicToken  String       @unique
  totalAmount  Decimal      @db.Decimal(12, 2)
  prizeAmount  Decimal      @default(0) @db.Decimal(12, 2)
  status       TicketStatus @default(PENDING)
  paidAt       DateTime?
  paidBy       String?      @db.Uuid
  cancelledAt  DateTime?
  cancelledBy  String?      @db.Uuid
  cancelReason String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user    User           @relation(fields: [userId], references: [id])
  race    Race           @relation(fields: [raceId], references: [id])
  details TicketDetail[]

  @@index([raceId])
  @@index([userId])
  @@index([raceId, userId])
}

model TicketCancellationCode {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  usedAt    DateTime?
  createdBy String   @db.Uuid
  createdAt DateTime @default(now())

  creator User @relation(fields: [createdBy], references: [id])

  @@index([createdBy])
  @@index([expiresAt])
  @@index([used])
}

model TicketDetail {
  id             String   @id @default(uuid()) @db.Uuid
  ticketId       String   @db.Uuid
  betType        BetType
  selection      String
  amount         Decimal  @db.Decimal(12, 2)
  odds           Decimal  @db.Decimal(12, 4)
  potentialPrize Decimal  @db.Decimal(12, 2)
  createdAt      DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id])

  @@index([ticketId])
}

model RaceOdds {
  id          String   @id @default(uuid()) @db.Uuid
  raceId      String   @db.Uuid
  betType     BetType
  selection   String
  totalAmount Decimal  @default(0) @db.Decimal(12, 2)
  currentOdds Decimal  @default(1) @db.Decimal(12, 4)
  finalOdds   Decimal? @db.Decimal(12, 4)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  race Race @relation(fields: [raceId], references: [id])

  @@unique([raceId, betType, selection])
  @@index([raceId])
  @@index([raceId, betType])
}
