generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CASHIER
  PLAYER
}

enum RaceStatus {
  OPEN
  CLOSED
  RUNNING
  FINISHED
}

enum TicketStatus {
  PENDING
  WON
  LOST
  PAID
}

enum BetType {
  WINNER
  EXACTA
  TRIFECTA
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  username  String   @unique
  email     String   @unique
  password  String
  role      Role     @default(PLAYER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets Ticket[]
}

model Video {
  id        String   @id @default(uuid()) @db.Uuid
  nombre    String   @unique
  resultado String
  archivo   String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  races Race[]
  queue VideoQueue[]
}

model Race {
  id        String     @id @default(uuid()) @db.Uuid
  numero    Int        @unique
  videoId   String     @db.Uuid
  resultado String
  status    RaceStatus @default(OPEN)
  openAt    DateTime?
  closeAt   DateTime?
  runAt     DateTime?
  finishedAt DateTime?
  saleStartAt DateTime?
  saleEndAt DateTime?
  videoStartedAt DateTime?
  videoFinishedAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  video Video @relation(fields: [videoId], references: [id])

  tickets Ticket[]
}

model VideoQueue {
  id        String   @id @default(uuid()) @db.Uuid
  videoId   String   @db.Uuid
  position  Int
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  video Video @relation(fields: [videoId], references: [id])

  @@index([used, position])
  @@index([videoId])
  @@unique([position])
}

model Ticket {
  id           String       @id @default(uuid()) @db.Uuid
  ticketNumber Int          @unique
  raceId       String       @db.Uuid
  userId       String       @db.Uuid
  totalAmount  Decimal      @db.Decimal(12, 2)
  status       TicketStatus @default(PENDING)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user    User           @relation(fields: [userId], references: [id])
  race    Race           @relation(fields: [raceId], references: [id])
  details TicketDetail[]

  @@index([raceId])
  @@index([userId])
  @@index([raceId, userId])
}

model TicketDetail {
  id             String   @id @default(uuid()) @db.Uuid
  ticketId       String   @db.Uuid
  betType        BetType
  selection      String
  amount         Decimal  @db.Decimal(12, 2)
  odds           Decimal  @db.Decimal(12, 4)
  potentialPrize Decimal  @db.Decimal(12, 2)
  createdAt      DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id])

  @@index([ticketId])
}
